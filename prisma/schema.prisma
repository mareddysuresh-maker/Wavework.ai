datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id
  name      String
  email     String   @unique
  avatarUrl String
  color     String
  timezone  String   @default("UTC")
  role      String   @default("EMPLOYEE")
  password  String   @default("password123")
  fileMetadata String @default("[]")
  workspaceId String   @default("w-1")
  activeWorkspaceId String @default("w-1")
  createdAt DateTime @default(now())
}

model Space {
  id          String  @id
  workspaceId String  @default("w-1")
  name        String
  color       String
  icon        String
  isPrivate   Boolean @default(false)
  memberIds   String  @default("[]")
  deletedAt   DateTime?
  deletedById String  @default("")
}

model Folder {
  id      String @id
  spaceId String
  name    String
  color   String @default("#6366f1")

  @@index([spaceId])
}

model List {
  id           String @id
  spaceId      String
  folderId     String @default("")
  name         String
  createdAt    String
  customFields String @default("[]")
  deletedAt    DateTime?
  deletedById  String @default("")

  @@index([spaceId])
  @@index([folderId])
}

model Task {
  id           String   @id
  listId       String
  parentTaskId String   @default("")
  name         String
  description  String   @default("")
  status       String   @default("TODO")
  priority     String   @default("NORMAL")
  assigneeId   String   @default("")
  startDate    String   @default("")
  dueDate      String   @default("")
  order        Int      @default(0)
  tags         String   @default("[]")
  timeEstimate Int      @default(0)
  timeTracked  Int      @default(0)
  customFields String   @default("{}")
  checklist    String   @default("[]")
  createdById         String   @default("")
  progress            Int      @default(25)
  isPersonal          Boolean  @default(false)
  taskSource          String   @default("admin_assigned")
  assignedById        String   @default("")
  deleteRequestStatus String   @default("")
  deleteRequestReason String   @default("")
  createdAt           String
  updatedAt           String
  deletedAt           DateTime?
  deletedById         String   @default("")

  @@index([listId])
  @@index([assigneeId])
}

model Channel {
  id            String   @id
  workspaceId   String   @default("w-1")
  name          String
  description   String   @default("")
  isPrivate     Boolean  @default(false)
  isDM          Boolean  @default(false)
  isGroup       Boolean  @default(false)
  memberIds     String   @default("[]")
  logoUrl       String   @default("")
  adminIds      String   @default("[]")
  lastMessageAt String   @default("")
  unreadCount   String   @default("{}")
  createdAt     String
  deletedAt     DateTime?
  deletedById   String   @default("")
}

model Message {
  id           String @id
  channelId    String
  authorId     String
  content      String
  parentId     String @default("")
  taskId       String @default("")
  savedByIds   String @default("[]")
  reactions    String @default("[]")
  attachments  String @default("[]")
  createdAt    String

  @@index([channelId])
  @@index([taskId])
}

model Notification {
  id         String   @id
  userId     String
  type       String
  title      String
  body       String
  entityId   String   @default("")
  entityType String   @default("")
  isRead     Boolean  @default(false)
  isSaved    Boolean  @default(false)
  createdAt  String
  workspaceId String  @default("w-1")
  readAt     DateTime?

  @@index([userId])
}

model ChatRequest {
  id            String @id
  senderId      String
  receiverEmail String
  receiverName  String
  status        String @default("PENDING")
  previewUrl    String @default("")
  createdAt     String
  workspaceId   String @default("w-1")
}

model Form {
  id          String  @id
  listId      String
  name        String
  description String  @default("")
  slug        String  @unique
  fields      String  @default("[]")
  isPublic    Boolean @default(true)
  createdAt   String

  @@index([listId])
}

model Note {
  id        String @id
  userId    String
  title     String @default("")
  content   String @default("")
  createdAt String
  updatedAt String

  @@index([userId])
}

model Sketch {
  id        String @id
  userId    String
  title     String @default("")
  bg        String @default("#ffffff")
  strokes   String @default("[]")
  createdAt String

  @@index([userId])
}

model PomodoroSettings {
  id            String  @id
  userId        String  @unique
  workDuration  Int     @default(25)
  shortBreak    Int     @default(5)
  longBreak     Int     @default(15)
  autoStartTime Boolean @default(false)
}

model PomodoroSession {
  id              String @id
  userId          String
  taskId          String @default("")
  durationMinutes Int
  type            String
  completedAt     String

  @@index([userId])
  @@index([taskId])
}

model Workspace {
  id          String   @id
  name        String
  description String   @default("")
  logoUrl     String   @default("")
  ownerId     String
  createdAt   DateTime @default(now())
  deletedAt   DateTime?
  deletedById String   @default("")
}

model Invitation {
  id          String   @id
  email       String
  role        String
  workspaceId String   @default("w-1")
  createdBy   String
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  status      String   @default("PENDING")
}

model ActivityLog {
  id          String   @id
  actorId     String
  workspaceId String   @default("w-1")
  eventType   String
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now())
}

model WorkspaceMembership {
  id          String   @id
  userId      String
  workspaceId String
  role        String   @default("EMPLOYEE")
  createdAt   DateTime @default(now())

  @@unique([userId, workspaceId])
  @@index([userId])
  @@index([workspaceId])
}

